// impl Add for Float32{ type Output = Float32;fn add(&self, rhs: &Float32)-> Float32{ /* intrinsic */ } }
// impl Add for Float64{ type Output = Float64;fn add(&self, rhs: &Float64)-> Float64{ /* intrinsic */ } }
// ... analogous impls for Sub, Mul, Div, Mod, Neg, Not, and all integer types.
