// ---------------------------------------------------------------------------
// Instant — monotonic clock
// ---------------------------------------------------------------------------

/// A measurement of a monotonic clock. Useful for measuring elapsed time.
struct Instant { /* internal: platform-specific monotonic timestamp */ }

impl Instant {
    /// Capture the current instant.
    fn now() -> Instant;

    /// Return the duration elapsed since this instant was captured.
    fn elapsed(&self) -> Duration;

    /// Return the duration between `self` and `later`.
    fn duration_since(&self, earlier: Instant) -> Duration;

    /// Checked duration_since (returns None if `earlier` is after `self`).
    fn checked_duration_since(&self, earlier: Instant) -> Option<Duration>;

    /// Return an instant that is `duration` in the future.
    fn add(&self, duration: Duration) -> Instant;

    /// Return an instant that is `duration` in the past.
    fn sub(&self, duration: Duration) -> Instant;
}

