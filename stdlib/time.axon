// ---------------------------------------------------------------------------
// Convenience functions
// ---------------------------------------------------------------------------

/// Measure the wall-clock time to execute `f`.
fn measure<T>(f: fn() -> T) -> (T, Duration);

/// Put the current thread to sleep for the given duration.
fn sleep(duration: Duration);
