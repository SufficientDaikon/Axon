/// std::nn::layers — Core neural network layers.
///
/// Provides Linear, Conv2d, BatchNorm, LayerNorm, Dropout,
/// MaxPool2d, AvgPool2d, and AdaptiveAvgPool2d layers.
/// All layers implement the Module trait with forward() and parameters().

/// Fully connected (dense) layer: y = x @ W^T + b.
struct Linear {
    in_features: Int64,
    out_features: Int64,
}

/// Create a new Linear layer.
fn linear_new(in_features: Int64, out_features: Int64) -> Int64 {
    // Allocates weight matrix [out_features x in_features] and bias [out_features].
    // Weight initialized with Kaiming uniform, bias with uniform(-1/sqrt(fan_in), 1/sqrt(fan_in)).
    // Requires CPU tensor runtime (Phase 10).
    return 0;
}

impl Module for Linear {
    fn forward(self, input: Int64) -> Int64 {
        // y = input @ self.weight^T + self.bias
        // matmul(input, transpose(self.weight)) + self.bias
        return 0;
    }

    fn parameters(self) -> Int64 {
        // Returns [self.weight, self.bias]
        return 0;
    }

    fn train(self) {
        // Linear has no training/eval mode distinction.
    }

    fn eval(self) {
        // Linear has no training/eval mode distinction.
    }

    fn to_device(self, device: Int64) {
        // Move weight and bias tensors to the specified device.
    }
}

/// 2D convolution layer.
