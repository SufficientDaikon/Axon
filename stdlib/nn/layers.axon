    in_channels: Int64,
    out_channels: Int64,
    kernel_size: Int64,
}

/// Create a new Conv2d layer.
fn conv2d_new(in_channels: Int64, out_channels: Int64, kernel_size: Int64) -> Int64 {
    // Allocates kernel [out_channels x in_channels x kernel_size x kernel_size]
    // and bias [out_channels]. Kaiming uniform initialization.
    // Requires CPU tensor runtime (Phase 10).
    return 0;
}

impl Module for Conv2d {
    fn forward(self, input: Int64) -> Int64 {
        // output = conv2d(input, self.weight, self.bias, stride=1, padding=0)
        // Sliding window cross-correlation + bias.
        return 0;
    }

    fn parameters(self) -> Int64 {
        // Returns [self.weight, self.bias]
        return 0;
    }

    fn train(self) {}
    fn eval(self) {}
    fn to_device(self, device: Int64) {}
}

/// Batch normalization over a mini-batch of inputs.
struct BatchNorm {
    num_features: Int64,
}

/// Create a new BatchNorm layer.
fn batchnorm_new(num_features: Int64) -> Int64 {
    // Allocates gamma (scale) and beta (shift) of size [num_features].
    // Tracks running mean and variance for eval mode.
    // Requires CPU tensor runtime (Phase 10).
    return 0;
}

impl Module for BatchNorm {
    fn forward(self, input: Int64) -> Int64 {
        // Training: normalize over batch using batch mean/var, update running stats.
        // Eval: normalize using running mean/var.
        // output = gamma * (input - mean) / sqrt(var + eps) + beta
        return 0;
    }

    fn parameters(self) -> Int64 {
        // Returns [self.gamma, self.beta]
        return 0;
    }

    fn train(self) {}
    fn eval(self) {}
    fn to_device(self, device: Int64) {}
}

/// Layer normalization over the last dimension.
struct LayerNorm {
    normalized_shape: Int64,
}

/// Create a new LayerNorm layer.
fn layernorm_new(normalized_shape: Int64) -> Int64 {
    // Allocates gamma and beta of size [normalized_shape].
    // Requires CPU tensor runtime (Phase 10).
    return 0;
}

impl Module for LayerNorm {
    fn forward(self, input: Int64) -> Int64 {
        // Normalize over last dimension:
        // output = gamma * (input - mean) / sqrt(var + eps) + beta
        return 0;
    }

    fn parameters(self) -> Int64 {
        // Returns [self.gamma, self.beta]
        return 0;
    }

    fn train(self) {}
    fn eval(self) {}
    fn to_device(self, device: Int64) {}
}

/// Randomly zeroes elements with probability p during training.
struct Dropout {
    p: Float32,
}

/// Create a new Dropout layer.
fn dropout_new(p: Float32) -> Int64 {
    // Stores dropout probability p.
    // Requires CPU tensor runtime (Phase 10).
    return 0;
}

impl Module for Dropout {
    fn forward(self, input: Int64) -> Int64 {
        // Training: randomly zero elements with probability p,
        //   scale remaining by 1/(1-p) to preserve expected value.
        // Eval: identity (no dropout).
        return input;
    }

    fn parameters(self) -> Int64 {
        // Dropout has no learnable parameters.
        return 0;
    }

    fn train(self) {}
    fn eval(self) {}
    fn to_device(self, device: Int64) {}
}

