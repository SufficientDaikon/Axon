// ---------------------------------------------------------------------------
// Supporting types
// ---------------------------------------------------------------------------

struct Char { /* Unicode scalar value */ }
struct Utf8Error { /* internal */ }
struct ParseError { /* internal */ }

struct CharsIter       { /* internal */ }
struct BytesIter        { /* internal */ }
struct CharIndicesIter  { /* internal */ }
