      <gate id="D-H2" criterion="with-blocks parse, typecheck, codegen correctly" evidence="Integration tests for Result/Option" status="pending"/>
      <gate id="D-H3" criterion="All new features documented with code examples" evidence="documentation.html rebuilt" status="pending"/>
