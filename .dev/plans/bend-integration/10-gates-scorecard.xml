      <gate id="E-H2" criterion="Performance projections include concrete target numbers" evidence="Projections section in each doc" status="pending"/>
      <gate id="E-H3" criterion="No dead code introduced — designs only" evidence="cargo test unchanged" status="pending"/>
    </hardGates>
    <softGates>
