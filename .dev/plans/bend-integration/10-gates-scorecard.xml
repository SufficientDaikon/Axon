      <gate id="G-H4" criterion="Non-linear params completely unaffected by linearity" evidence="Existing borrow tests pass unchanged" status="pending"/>
      <gate id="G-H5" criterion="--enum-layout flag produces different codegen" evidence="LLVM IR diff for tagged vs packed" status="pending"/>
      <gate id="G-H6" criterion="Default enum layout behavior unchanged" evidence="All existing enum tests pass" status="pending"/>
    </hardGates>
    <softGates>
      <gate id="G-S1" criterion="Linearity error message quality" maxScore="3" score="0" status="pending"/>
      <gate id="G-S2" criterion="ADT layout benchmark results" maxScore="3" score="0" status="pending"/>
      <gate id="G-S3" criterion="New test count (target: 30+ new in GAMMA)" maxScore="3" score="0" status="pending"/>
    </softGates>
    <exitCriteria>
      <hardPassed>0/6</hardPassed>
      <softAverage>0.0/3.0</softAverage>
      <decision>BLOCKED</decision>
    </exitCriteria>
  </gate>

  <!-- ═══════════════════════════════════════════════════════════════
       DELTA GATE — LANGUAGE ERGONOMICS
       ═══════════════════════════════════════════════════════════════ -->
  <gate phase="DELTA" name="Language Ergonomics">
